{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zapret-next.local/schemas/strategy.schema.json",
  "title": "Zapret Strategy Spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "specVersion",
    "id",
    "priority",
    "sourceBat",
    "filters",
    "desyncParams",
    "requiredAssets"
  ],
  "properties": {
    "specVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "priority": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000
    },
    "sourceBat": {
      "type": "string",
      "minLength": 1
    },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "binary": { "type": "string" },
        "wfTcp": { "type": ["string", "null"] },
        "wfUdp": { "type": ["string", "null"] }
      },
      "required": ["binary", "wfTcp", "wfUdp"]
    },
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stages"],
      "properties": {
        "stages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["index", "filters", "desyncParams", "requiredAssets"],
            "properties": {
              "index": { "type": "integer", "minimum": 0 },
              "filters": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "desyncParams": {
                "type": "object",
                "minProperties": 1,
                "additionalProperties": { "type": "string" }
              },
              "requiredAssets": {
                "type": "array",
                "items": { "type": "string" },
                "uniqueItems": true
              }
            }
          }
        }
      }
    },
    "desyncParams": {
      "type": "object",
      "additionalProperties": true
    },
    "requiredAssets": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    }
  }
}
